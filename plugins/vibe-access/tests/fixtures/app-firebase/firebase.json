{
  "hosting": {
    "public": "frontend/dist",
    "rewrites": [
      { "source": "/api/leaderboard", "function": "leaderboard" },
      { "source": "/api/submit-score", "function": "submitScore" },
      { "source": "/api/ping", "function": "ping" },
      { "source": "/api/echo", "function": "echo" },
      { "source": "/api/echo-back", "function": "echoBack" },
      { "source": "/api/ghost", "function": "ghostFunction" },
      { "source": "/api/quiz-data", "function": "getQuizData" },
      { "source": "/api/quiz-save", "function": "saveQuiz" },
      { "source": "/api/admin/generate-anagrams", "function": "generateAnagramsBatch" },
      { "source": "/api/profile", "function": "getProfile" },
      { "source": "/api/profile-update", "function": "updateProfile" },
      { "source": "/api/public-feed", "function": "publicFeed" },
      { "source": "/api/public-feed-alias", "function": "feedAlias" },
      { "source": "/api/screenings", "function": "screeningsFeed" },
      { "source": "/api/screenings/details", "function": "screeningDetails" },
